{
    "name": "togul/laravel-sdk",
    "description": "Laravel integration for Togul Feature Flag Service",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "togul/php-sdk": "*",
        "illuminate/support": "^10.0|^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Togul\\Laravel\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Togul\\Laravel\\TogulServiceProvider"
            ],
            "aliases": {
                "Togul": "Togul\\Laravel\\Facades\\Togul"
            }
        }
    },
    "minimum-stability": "stable"
}
