{
    "name": "nori/laravel-sdk",
    "description": "Laravel integration for Nori Feature Flag Service",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "nori/php-sdk": "*",
        "illuminate/support": "^10.0|^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Nori\\Laravel\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Nori\\Laravel\\NoriServiceProvider"
            ],
            "aliases": {
                "Nori": "Nori\\Laravel\\Facades\\Nori"
            }
        }
    },
    "minimum-stability": "stable"
}
